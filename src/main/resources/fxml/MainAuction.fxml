<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.MainAuctionController" prefWidth="1100" prefHeight="760"
            stylesheets="@../styles/app.css" styleClass="page-bg">
    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="main-header">
            <Label text="SÀN ĐẤU GIÁ TRỰC TUYẾN" styleClass="header-title" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" text="Xin chào, User" styleClass="header-user" />
            <Button text="Đăng xuất" onAction="#handleLogout" styleClass="btn-danger" />
        </HBox>
    </top>
    
    <!-- Phần thân chứa danh sách đấu giá -->
    <center>
        <VBox spacing="16" styleClass="main-content">
            <HBox spacing="12">
                <children>
                    <VBox prefWidth="250" styleClass="stat-card">
                        <children>
                            <Label text="Phiên đang mở" styleClass="stat-title"/>
                            <Label text="Live Tracking" styleClass="stat-value"/>
                            <Label text="Theo dõi các phiên RUNNING và EXTENDED." styleClass="stat-desc" wrapText="true"/>
                        </children>
                    </VBox>
                    <VBox prefWidth="250" styleClass="stat-card">
                        <children>
                            <Label text="Tính năng realtime" styleClass="stat-title"/>
                            <Label text="Socket Push" styleClass="stat-value"/>
                            <Label text="Giá mới được đồng bộ tới toàn bộ client." styleClass="stat-desc" wrapText="true"/>
                        </children>
                    </VBox>
                    <VBox prefWidth="250" styleClass="stat-card">
                        <children>
                            <Label text="Trạng thái hệ thống" styleClass="stat-title"/>
                            <Label text="Ổn định" styleClass="stat-value"/>
                            <Label text="Sẵn sàng cho đấu giá đồng thời nhiều người dùng." styleClass="stat-desc" wrapText="true"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Label text="Danh sách các phiên đấu giá" styleClass="section-title" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="auction-scroll">
                <content>
                    <VBox fx:id="auctionCardsContainer" spacing="10.0" styleClass="auction-cards-wrap">
                        <children>
                            <Label fx:id="lblEmptyAuctions" text="Chưa có phiên đấu giá nào." styleClass="empty-hint"/>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
    
    <!-- Phần chân (Bottom) chứa các nút hành động -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="main-footer">
            <Button fx:id="btnCreateAuction" text="Tạo phiên đấu giá mới" onAction="#handleCreateAuction" styleClass="btn-success" />
            <Button fx:id="btnJoinAuction" text="Tham gia đấu giá" onAction="#handleJoinAuction" styleClass="btn-primary" />
        </HBox>
    </bottom>
</BorderPane>
