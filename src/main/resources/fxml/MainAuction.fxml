<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainAuctionController" prefWidth="850" prefHeight="600">
    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15px;">
            <Label text="SÀN ĐẤU GIÁ TRỰC TUYẾN" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" text="Xin chào, User" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;" />
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
        </HBox>
    </top>
    
    <!-- Phần thân chứa danh sách đấu giá -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20px;">
            <Label text="Danh sách các phiên đấu giá" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <TableView fx:id="tableAuctions" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                <columns>
                    <TableColumn fx:id="colId" text="Mã Phiên" prefWidth="100"/>
                    <TableColumn fx:id="colItem" text="Tên Sản Phẩm" prefWidth="300"/>
                    <TableColumn fx:id="colPrice" text="Giá Cao Nhất" prefWidth="150"/>
                    <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
    
    <!-- Phần chân (Bottom) chứa các nút hành động -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15px 20px; -fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Button fx:id="btnCreateAuction" text="Tạo phiên đấu giá mới" onAction="#handleCreateAuction" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 8px 15px; -fx-font-weight: bold;" />
            <Button fx:id="btnJoinAuction" text="Tham gia đấu giá" onAction="#handleJoinAuction" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 20px;" />
        </HBox>
    </bottom>
</BorderPane>
