<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.CreateAuctionController" prefWidth="600" prefHeight="550" style="-fx-background-color: #f4f6f9;">
    <padding>
        <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
    </padding>

    <Label text="TẠO PHIÊN ĐẤU GIÁ MỚI" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <GridPane hgap="15" vgap="15" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints minWidth="120" halignment="RIGHT" />
            <ColumnConstraints minWidth="300" />
        </columnConstraints>

        <Label text="Tên sản phẩm (*):" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtItemName" promptText="VD: Macbook Pro M3" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Danh mục:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbCategory" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Giá khởi điểm (*):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtStartPrice" promptText="Nhập số tiền (VNĐ)" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Thời gian (Phút) (*):" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtDuration" promptText="VD: 60 (tương đương 1 tiếng)" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Mô tả chi tiết:" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="TOP" style="-fx-font-weight: bold; -fx-padding: 5 0 0 0;"/>
        <TextArea fx:id="txtDescription" promptText="Thông tin tình trạng sản phẩm..." prefRowCount="4" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20 0 0 0;">
        <Button text="Hủy bỏ" onAction="#handleCancel" prefWidth="120" prefHeight="35" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Button text="Đăng Sản Phẩm" onAction="#handleCreate" prefWidth="180" prefHeight="35" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>
</VBox>
