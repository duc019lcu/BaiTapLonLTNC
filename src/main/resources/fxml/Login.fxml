<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" spacing="22.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.LoginController" prefWidth="980" prefHeight="600"
      stylesheets="@../styles/app.css" styleClass="page-bg">
    <padding>
        <Insets bottom="26.0" left="26.0" right="26.0" top="26.0"/>
    </padding>

    <children>
        <VBox spacing="14.0" prefWidth="460.0" styleClass="hero-panel">
            <children>
                <Label text="AuctionX" styleClass="brand-title"/>
                <Label text="Nền tảng đấu giá trực tuyến realtime cho Seller và Bidder."
                       wrapText="true" styleClass="hero-subtitle"/>

                <HBox spacing="12.0">
                    <children>
                        <VBox prefWidth="136.0" styleClass="info-card">
                            <children>
                                <Label text="99.9%" styleClass="info-value"/>
                                <Label text="Uptime máy chủ" styleClass="info-label"/>
                            </children>
                        </VBox>
                        <VBox prefWidth="136.0" styleClass="info-card">
                            <children>
                                <Label text="Realtime" styleClass="info-value"/>
                                <Label text="Cập nhật giá tức thì" styleClass="info-label"/>
                            </children>
                        </VBox>
                        <VBox prefWidth="136.0" styleClass="info-card">
                            <children>
                                <Label text="24/7" styleClass="info-value"/>
                                <Label text="Theo dõi phiên mọi lúc" styleClass="info-label"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="12.0" prefWidth="430.0" maxWidth="430.0" styleClass="form-panel">
            <children>
                <Label text="Đăng nhập" styleClass="panel-title"/>
                <Label text="Chào mừng quay lại, mời bạn đăng nhập để tiếp tục."
                       wrapText="true" styleClass="panel-subtitle"/>
                <Region prefHeight="4.0"/>

                <Label text="Tên đăng nhập" styleClass="field-label"/>
                <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" prefHeight="42.0" styleClass="text-input"/>

                <Label text="Mật khẩu" styleClass="field-label"/>
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" prefHeight="42.0" styleClass="text-input"/>

                <Region prefHeight="6.0"/>
                <Button text="Đăng nhập ngay" onAction="#handleLogin" prefHeight="44.0" maxWidth="1.7976931348623157E308"
                        styleClass="btn-primary"/>
                <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" onAction="#goToRegister" styleClass="link-inline"/>
                <Label fx:id="lblMessage" wrapText="true" styleClass="error-label"/>
            </children>
        </VBox>
    </children>
</HBox>
