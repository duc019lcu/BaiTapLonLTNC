<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.onlineauctionsystem.controller.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="HỆ THỐNG ĐẤU GIÁ" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
        <TextField fx:id="txtUsername" promptText="Tên đăng nhập" maxWidth="250" />
        <PasswordField fx:id="txtPassword" promptText="Mật khẩu" maxWidth="250" />
        <Button text="Đăng nhập" onAction="#handleLogin" prefWidth="100" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
        <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" onAction="#goToRegister" />
        <Label fx:id="lblMessage" textFill="RED" />
    </children>
</VBox>
