<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController" prefWidth="600" prefHeight="450" style="-fx-background-color: #f4f6f9;">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <Label text="HỆ THỐNG ĐẤU GIÁ" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Label text="Đăng nhập để tiếp tục" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" />
        
        <VBox spacing="5" maxWidth="300">
            <Label text="Tên đăng nhập" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" prefHeight="40" style="-fx-font-size: 14px; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
        </VBox>
        
        <VBox spacing="5" maxWidth="300">
            <Label text="Mật khẩu" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" prefHeight="40" style="-fx-font-size: 14px; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
        </VBox>

        <Button text="Đăng nhập" onAction="#handleLogin" prefWidth="300" prefHeight="45" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 5;" />
        
        <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" onAction="#goToRegister" style="-fx-text-fill: #2980b9; -fx-font-size: 14px;" />
        
        <Label fx:id="lblMessage" textFill="#e74c3c" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
    </children>
</VBox>
