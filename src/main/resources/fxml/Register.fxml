<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.RegisterController" prefWidth="600" prefHeight="550" style="-fx-background-color: #f4f6f9;">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="ĐĂNG KÝ TÀI KHOẢN" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Label text="Vui lòng điền đầy đủ thông tin" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-padding: 0 0 10 0;" />
        
        <VBox spacing="5.0" maxWidth="350">
            <Label text="Tên đăng nhập (*)" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <TextField fx:id="txtUser" promptText="Nhập tên đăng nhập" prefHeight="40" style="-fx-font-size: 14px;" />
        </VBox>

        <VBox spacing="5.0" maxWidth="350">
            <Label text="Mật khẩu (*)" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <PasswordField fx:id="txtPass" promptText="Nhập mật khẩu" prefHeight="40" style="-fx-font-size: 14px;" />
        </VBox>

        <VBox spacing="5.0" maxWidth="350">
            <Label text="Email (*)" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <TextField fx:id="txtEmail" promptText="VD: user@gmail.com" prefHeight="40" style="-fx-font-size: 14px;" />
        </VBox>

        <VBox spacing="5.0" maxWidth="350">
            <Label text="Địa chỉ" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <TextField fx:id="txtAddress" promptText="Nhập địa chỉ của bạn" prefHeight="40" style="-fx-font-size: 14px;" />
        </VBox>

        <VBox spacing="5.0" maxWidth="350">
            <Label text="Vai trò (*)" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <ComboBox fx:id="cbRole" prefWidth="350" prefHeight="40" style="-fx-font-size: 14px;" />
        </VBox>

        <Label fx:id="lblError" textFill="#e74c3c" style="-fx-font-weight: bold;" />

        <Button text="Đăng ký ngay" onAction="#handleRegister" prefWidth="350" prefHeight="45" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 5;" />
        
        <Hyperlink text="Đã có tài khoản? Quay lại đăng nhập" onAction="#handleLoginRedirect" style="-fx-text-fill: #2980b9; -fx-font-size: 14px;" />
    </children>
</VBox>
