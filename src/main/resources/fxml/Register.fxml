<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.RegisterController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="ĐĂNG KÝ TÀI KHOẢN" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        
        <VBox spacing="5.0" maxWidth="300">
            <Label text="Tên đăng nhập (*)" />
            <TextField fx:id="txtUser" promptText="Nhập tên đăng nhập" />
        </VBox>

        <VBox spacing="5.0" maxWidth="300">
            <Label text="Mật khẩu (*)" />
            <PasswordField fx:id="txtPass" promptText="Nhập mật khẩu" />
        </VBox>

        <VBox spacing="5.0" maxWidth="300">
            <Label text="Email" />
            <TextField fx:id="txtEmail" promptText="Nhập địa chỉ email" />
        </VBox>

        <VBox spacing="5.0" maxWidth="300">
            <Label text="Địa chỉ" />
            <TextField fx:id="txtAddress" promptText="Nhập địa chỉ của bạn" />
        </VBox>

        <VBox spacing="5.0" maxWidth="300">
            <Label text="Vai trò (*)" />
            <ComboBox fx:id="cbRole" prefWidth="300" />
        </VBox>

        <Button text="Đăng ký" onAction="#handleRegister" prefWidth="300" prefHeight="35" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
        
        <Hyperlink text="Đã có tài khoản? Quay lại đăng nhập" onAction="#handleLoginRedirect" style="-fx-text-fill: #2980b9;" />
    </children>
</VBox>
