<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionRoomController" prefWidth="1000" prefHeight="700">
    
    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 15px;">
            <Button text="← Trở lại" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-border-color: #ecf0f1; -fx-border-radius: 5; -fx-cursor: hand;" />
            <Label text="PHÒNG ĐẤU GIÁ TRỰC TIẾP" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- CENTER (Main Content) -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20px;">
            
            <!-- Cột trái: Thông tin sản phẩm & Đồng hồ -->
            <VBox spacing="15" prefWidth="350" style="-fx-background-color: #f8f9fa; -fx-padding: 20px; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                <Label fx:id="lblItemName" text="Tên Sản Phẩm" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2980b9; -fx-wrap-text: true;" />
                
                <Label text="Thông tin chi tiết:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 0 0 0;" />
                <Label fx:id="lblDescription" text="Mô tả..." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #555;" />
                
                <Separator />
                
                <!-- Khu vực đếm ngược -->
                <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 15px; -fx-border-radius: 8;">
                    <Label text="THỜI GIAN CÒN LẠI" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                    <Label fx:id="lblTimer" text="00:00:00" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                </VBox>
                
                <!-- Khu vực người dẫn đầu -->
                <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #e8f8f5; -fx-padding: 15px; -fx-border-radius: 8; -fx-border-color: #1abc9c; -fx-border-width: 2;">
                    <Label text="NGƯỜI DẪN ĐẦU HIỆN TẠI" style="-fx-font-weight: bold; -fx-text-fill: #16a085;" />
                    <Label fx:id="lblWinner" text="Chưa có" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                </VBox>
            </VBox>

            <!-- Cột phải: Biểu đồ và Form đặt giá -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <!-- Vùng hiển thị giá cao nhất -->
                <VBox alignment="CENTER" style="-fx-background-color: #fff9c4; -fx-padding: 20px; -fx-border-color: #fbc02d; -fx-border-radius: 8; -fx-border-width: 2;">
                    <Label text="GIÁ CAO NHẤT HIỆN TẠI" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                    <Label fx:id="lblCurrentPrice" text="0 VNĐ" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
                </VBox>

                <!-- Biểu đồ lịch sử giá (Yêu cầu nâng cao) -->
                <LineChart fx:id="bidChart" title="Biểu đồ đường cong giá (Realtime Price Curve)" VBox.vgrow="ALWAYS" animated="false">
                    <xAxis>
                        <CategoryAxis label="Thời gian" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Giá (VNĐ)" />
                    </yAxis>
                </LineChart>

                <!-- Form đặt giá -->
                <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #f1f2f6; -fx-padding: 20px; -fx-border-radius: 8;">
                    <Label text="Nhập giá mới:" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                    <TextField fx:id="txtBidAmount" promptText="Giá phải cao hơn giá hiện tại" prefWidth="250" prefHeight="40" style="-fx-font-size: 16px;" />
                    <Button text="ĐẶT GIÁ NGAY" onAction="#handlePlaceBid" prefHeight="40" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand;" />
                </HBox>
            </VBox>
            
        </HBox>
    </center>
    
</BorderPane>
