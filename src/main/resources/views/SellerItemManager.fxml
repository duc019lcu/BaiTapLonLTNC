<?xml version="1.0" encoding="UTF-8"?>

<!--File này thiết kế giao diện, place các nút, ô điền,.. các ô đc connect với SellerController.java và đc trang trí bởi css -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bai_tap_lon.controller.SellerController"
      stylesheets="@../styles/style.css"
      prefWidth="1180" prefHeight="720"
      styleClass="root"
      spacing="0">

    <!-- ═══ HEADER BAR ═══ -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="14">
        <!-- Accent dot -->
        <Rectangle width="4" height="28" arcWidth="4" arcHeight="4"
                   fill="#3B82F6" opacity="0.9"/>

        <VBox spacing="1">
            <Label text="QUẢN LÝ KHO HÀNG" styleClass="app-title"/>
            <Label text="SELLER ITEM MANAGER  ·  AUCTION SYSTEM" styleClass="app-subtitle"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Status badges top-right -->
        <Label text="● ONLINE" style="-fx-text-fill: #34D399; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        <Label text="SELLER MODE" style="-fx-background-color: rgba(59,130,246,0.15);
                                         -fx-border-color: rgba(59,130,246,0.30);
                                         -fx-border-width: 1;
                                         -fx-background-radius: 6; -fx-border-radius: 6;
                                         -fx-text-fill: #60A5FA; -fx-font-size: 10px;
                                         -fx-font-weight: bold; -fx-padding: 4 10 4 10;"/>
    </HBox>

    <!-- ═══ MAIN CONTENT ═══ -->
    <HBox spacing="18" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="18" right="20" bottom="20" left="20"/>
        </padding>

        <!-- ─── LEFT PANEL: FORM ─── -->
        <VBox fx:id="formPanel" spacing="14" prefWidth="410" styleClass="glass-panel">
            <padding>
                <Insets top="22" right="22" bottom="22" left="22"/>
            </padding>

            <!-- Section: General Info -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="THÔNG TIN SẢN PHẨM" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="GENERAL" styleClass="section-badge"/>
            </HBox>

            <VBox spacing="9">
                <TextField fx:id="txtId"        promptText="  Mã sản phẩm (ID)"/>
                <TextField fx:id="txtName"      promptText="  Tên sản phẩm"/>
                <TextArea  fx:id="txtDescription" promptText="  Mô tả sản phẩm..."
                           prefHeight="70" wrapText="true"/>
                <TextField fx:id="txtInitPrice" promptText="  Giá khởi điểm (VND)"/>
            </VBox>

            <!-- Separator -->
            <HBox alignment="CENTER" spacing="10">
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-border-color: rgba(80,120,200,0.15); -fx-border-width: 0 0 1 0;"/>
            </HBox>

            <!-- Section: Category -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="PHÂN LOẠI HÀNG HÓA" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="CATEGORY" styleClass="section-badge"/>
            </HBox>

            <ComboBox fx:id="cbCategory"
                      promptText="— Chọn loại hàng —"
                      prefWidth="366"
                      onAction="#handleCategoryChange"/>

            <!-- Dynamic sub-panels -->
            <VBox fx:id="paneDynamicFields" spacing="0">

                <!-- ELECTRONICS -->
                <VBox fx:id="vboxElectronics" spacing="8"
                      visible="false" managed="false" styleClass="sub-panel">
                    <Label text="⚡  ELECTRONICS" styleClass="section-title"
                           style="-fx-font-size: 10px; -fx-padding: 0 0 4 0;"/>
                    <TextField fx:id="txtElec1" promptText="  Thương hiệu"/>
                    <TextField fx:id="txtElec2" promptText="  Bảo hành (tháng) — số"/>
                    <TextField fx:id="txtElec3" promptText="  Model"/>
                    <TextField fx:id="txtElec4" promptText="  Thông số kỹ thuật khác"/>
                </VBox>

                <!-- ART -->
                <VBox fx:id="vboxArt" spacing="8"
                      visible="false" managed="false" styleClass="sub-panel">
                    <Label text="🎨  ART" styleClass="section-title"
                           style="-fx-font-size: 10px; -fx-padding: 0 0 4 0;"/>
                    <TextField fx:id="txtArt1" promptText="  Nghệ sĩ / Tác giả"/>
                    <TextField fx:id="txtArt2" promptText="  Năm sáng tác — số"/>
                    <TextField fx:id="txtArt3" promptText="  Kỹ thuật vẽ / Chất liệu"/>
                </VBox>

                <!-- VEHICLE -->
                <VBox fx:id="vboxVehicle" spacing="8"
                      visible="false" managed="false" styleClass="sub-panel">
                    <Label text="🚗  VEHICLE" styleClass="section-title"
                           style="-fx-font-size: 10px; -fx-padding: 0 0 4 0;"/>
                    <TextField fx:id="txtVeh1" promptText="  Hãng xe"/>
                    <TextField fx:id="txtVeh2" promptText="  Loại động cơ"/>
                    <TextField fx:id="txtVeh3" promptText="  Số dặm đã đi — số"/>
                </VBox>

                <!-- FASHION -->
                <VBox fx:id="vboxFashion" spacing="8"
                      visible="false" managed="false" styleClass="sub-panel">
                    <Label text="👔  FASHION" styleClass="section-title"
                           style="-fx-font-size: 10px; -fx-padding: 0 0 4 0;"/>
                    <TextField fx:id="txtFas1" promptText="  Kích cỡ (Size)"/>
                    <TextField fx:id="txtFas2" promptText="  Chất liệu"/>
                    <TextField fx:id="txtFas3" promptText="  Thương hiệu"/>
                </VBox>

                <!-- FURNITURE -->
                <VBox fx:id="vboxFurniture" spacing="8"
                      visible="false" managed="false" styleClass="sub-panel">
                    <Label text="🪑  FURNITURE" styleClass="section-title"
                           style="-fx-font-size: 10px; -fx-padding: 0 0 4 0;"/>
                    <TextField fx:id="txtFur1" promptText="  Chất liệu"/>
                    <TextField fx:id="txtFur2" promptText="  Kích thước (cm)"/>
                </VBox>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Action Buttons -->
            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="btnAdd"
                        text="＋  THÊM MỚI"
                        onAction="#handleAdd"
                        styleClass="btn-success"
                        prefWidth="168" prefHeight="44"/>
                <Button fx:id="btnDelete"
                        text="✕  XÓA"
                        onAction="#handleDelete"
                        styleClass="btn-danger"
                        prefWidth="110" prefHeight="44"/>
            </HBox>

        </VBox>

        <!-- ─── RIGHT PANEL: TABLE ─── -->
        <VBox HBox.hgrow="ALWAYS" spacing="14" styleClass="glass-panel">
            <padding>
                <Insets top="22" right="22" bottom="22" left="22"/>
            </padding>

            <!-- Table header -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2">
                    <Label text="KHO HÀNG HÓA" styleClass="section-title"
                           style="-fx-font-size: 13px;"/>
                    <Label text="Nhấp vào hàng để chọn — Nhấn XÓA để xoá"
                           style="-fx-text-fill: #3D5275; -fx-font-size: 10.5px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCount" text="INVENTORY"
                       style="-fx-background-color: rgba(59,130,246,0.12);
                              -fx-border-color: rgba(59,130,246,0.25);
                              -fx-border-width: 1;
                              -fx-background-radius: 6; -fx-border-radius: 6;
                              -fx-text-fill: #4A7AC0; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 4 10 4 10;"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tableItems" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"       text="MÃ ĐỊNH DANH"   prefWidth="140"/>
                    <TableColumn fx:id="colName"     text="TÊN SẢN PHẨM"  prefWidth="160"/>
                    <TableColumn fx:id="colCategory" text="LOẠI"           prefWidth="110"/>
                    <TableColumn fx:id="colPrice"    text="GIÁ (VND)"      prefWidth="130"/>
                    <TableColumn fx:id="colDesc"     text="MÔ TẢ CHI TIẾT" prefWidth="260"/>
                </columns>
                <placeholder>
                    <Label text="Kho hàng trống — Hãy thêm sản phẩm đầu tiên"
                           style="-fx-text-fill: #3D5275; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </HBox>

</VBox>